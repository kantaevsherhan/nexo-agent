{
  "name": "nexo-agent",
  "version": "0.1.0",
  "description": "Node.js/TypeScript agent inspired by Hermes Agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nexo": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "llm",
    "ai",
    "typescript"
  ],
  "license": "MIT",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react": "^19.2.17",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.5",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.2.0",
    "openai": "^6.42.0",
    "react": "^19.2.7",
    "retry": "^0.13.1",
    "telegraf": "^4.16.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/retry": "^0.12.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
